      "tumor_detected": true,
      "confidence": 0.9147,
      "raw_score": 0.9147,
      "tumor_size": "large",
      "risk_level": "High",
      "risk_probability": 0.8732,
      "risk_rationale": "Large high-confidence tumor detected. Emergency intervention likely needed.",
      "patient_age": 58,
      "patient_gender": "M",
      "symptoms": ["headache", "vision changes", "nausea"],
