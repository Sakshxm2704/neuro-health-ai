{
  "POST /api/v1/upload-mri": {
    "description": "Upload an MRI image for full AI analysis pipeline",
    "request": {
      "method": "POST",
      "content_type": "multipart/form-data",
      "fields": {
        "file": "<mri_image.jpg>",
        "patient_age": 58,
        "patient_gender": "M",
        "symptoms": "headache,vision changes,nausea",
        "medical_history": "hypertension,diabetes"
      }
    },
    "response_201": {
      "scan_id": "SCAN-A3F9B21C04",
      "status": "analyzed",
      "tumor_detected": true,
      "confidence": 0.9147,
      "risk_level": "High",
      "risk_probability": 0.8732,
      "urgency": "Immediate",
      "doctor_type": "Neurosurgeon (Senior)",
      "suggested_action": "Emergency neurosurgical assessment and ICU admission.",
      "next_steps": [
        "Activate emergency protocol immediately",
        "Transfer patient to ICU",
        "Order contrast-enhanced MRI within 2 hours",
        "Alert on-call neurosurgeon",
        "Initiate IV corticosteroids to reduce cerebral edema",
        "Consent for possible surgical intervention",
        "Notify next-of-kin"
      ],
      "icu_bed_assigned": true,
      "doctor_assigned": true,
      "ot_room_assigned": true,
      "resource_message": "Emergency allocation complete. ICU Bed 3, DR-002 assigned, OT Room 1 reserved.",
      "message": "Scan 'mri_image.jpg' analyzed successfully. Tumor detected. Risk: High. Action: Immediate."
    },
    "response_400_invalid_file": {
      "detail": "Invalid file type 'application/pdf'. Upload JPEG or PNG MRI images."
    }
  },

  "GET /api/v1/prediction/{scan_id}": {
    "description": "Retrieve CNN prediction & risk classification for a scan",
    "request": {
      "method": "GET",
      "url": "/api/v1/prediction/SCAN-A3F9B21C04"
